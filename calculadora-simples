# Calculadora simples (iniciante)

print("Calculadora básica")

# Pedindo números
num1 = float(input("Digite o primeiro número: "))
num2 = float(input("Digite o segundo número: "))

# Escolhendo operação
operacao = input("Escolha a operação (+, -, *, /): ")

# Fazendo o cálculo
if operacao == "+":
    resultado = num1 + num2
elif operacao == "-":
    resultado = num1 - num2
elif operacao == "*":
    resultado = num1 * num2
elif operacao == "/":
    if num2 != 0:
        resultado = num1 / num2
    else:
        resultado = "Erro: divisão por zero"
else:
    resultado = "Operação inválida"

# Mostrando resultado
print("Resultado:", resultado)
